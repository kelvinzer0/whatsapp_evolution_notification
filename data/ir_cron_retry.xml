<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron: Retry failed WA messages every 15 minutes -->
        <record id="cron_retry_failed_whatsapp" model="ir.cron">
            <field name="name">WhatsApp: Retry Failed Messages</field>
            <field name="model_id" ref="model_whatsapp_message_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_retry_failed()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron: Cleanup old logs every Sunday 03:00 -->
        <record id="cron_cleanup_old_logs" model="ir.cron">
            <field name="name">WhatsApp: Cleanup Old Logs (>90 days)</field>
            <field name="model_id" ref="model_whatsapp_message_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_old_logs(days=90)</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
